# RPC endpoint for Soroban Testnet/Futurenet
RPC_URL="https://soroban-testnet.stellar.org"
HORIZON_URL="https://horizon-testnet.stellar.org"

# Network Passphrase
NETWORK_PASSPHRASE="Test SDF Network ; September 2015"

# Relayer Keypair Secret (DO NOT COMMIT THE REAL .env FILE!)
RELAYER_SECRET="S..."

# Testnet-only ASP enrollment signer and persistent membership-path storage.
ASP_ADMIN_SECRET="S..."
ASP_MEMBERSHIP_ID="C..."
DATABASE_URL="postgresql://..."
ASP_MAX_ENROLLMENTS=128

# Comma-separated list of allowed contract addresses
ALLOWED_POOLS="C..."

# Port for the API server
PORT=3002
